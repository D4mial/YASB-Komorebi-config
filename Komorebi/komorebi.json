{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.38/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 2,
  "default_container_padding": 1,
  "floating_applications": [
    {
      "kind": "Title",
      "id": "Write:",
      "matching_strategy": "StartsWith"
    },
    {
      "kind": "Exe",
      "id": "quick-picture-viewer.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "obs64.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "Privacy and Network Access Policy",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Title",
      "id": "File Converter",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Exe",
      "id": "StartAllBackCfg.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Photoshop.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Illustrator.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "PicView.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "Screenbox",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "prismlauncher.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Yasb_themes.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "ResourceHacker.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "fdm.exe",
      "matching_strategy": "Equals"       
    },
    {
      "kind": "Class",
      "id": "RarReminder",
      "matching_strategy": "Equals"       
    },
    {
      "kind": "Class",
      "id": "BootstrapUpdateUIClass",
      "matching_strategy": "Equals"
    }
  ],
  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "Yasb.exe",
      "matching_strategy": "Equals"
    }
  ],
  "mouse_follows_focus": false,
  "transparency": true,
  "transparency_alpha": 200,
  "transparency_ignore_rules": [
    {
      "kind": "Exe",
      "id": "obs64.exe", 
      "matching_strategy": "Equals"
    }
  ],
  "animation": {
    "enabled": true,
    "fps": 120,
    "duration": 200,
      "style": {
        "movement":"EaseOutBack",
        "transparency": "Linear"
      }
  },
  "border": true,
  "border_implementation": "Komorebi",
  "border_style": "Rounded",
  "border_width": 4,
  "border_colours": {
    "single": "#ffffff",
    "unfocused": "#ffffff",
    "floating": "#f6c177",
    "stack": "#cba6f7"
  },  
  "stackbar": {
    "height": 25,
    "mode": "Never",
    "tabs": {
      "width": 125,
      "focused_text": "#74c7ec",
      "unfocused_text": "#cdd6f4",
      "background": "#1e1e2e",
      "font_family": "JetBrainsMono Nerd Font",
      "font_size": 14
    }
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP"
        },
        {
          "name": "II",
          "layout": "UltrawideVerticalStack"
        },
        {
          "name": "III",
          "layout": "Grid"
        },
        {
          "name": "IV",
          "layout": "VerticalStack"
        },
        {
          "name": "V",
          "layout": "RightMainVerticalStack"
        },
        {
          "name": "VI",
          "layout": "HorizontalStack"
        }
      ]
    }
  ]
}
